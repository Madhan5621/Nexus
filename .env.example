# Copy this file to .env for local development (server.js loads it via dotenv).
# In Vercel, set these same values under Project Settings → Environment Variables instead.

# Supabase project URL — find it in Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase "service_role" secret key — Supabase Dashboard → Project Settings → API
# (Keep this private. Never expose it in frontend code.)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Any long random string, used to sign login tokens
JWT_SECRET=replace-with-a-long-random-string

# Port for local dev server only (Vercel ignores this)
PORT=3000
