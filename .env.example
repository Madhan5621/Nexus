# Copy this file to .env.local for local development with `vercel dev`,
# OR (recommended) set these directly in your Vercel project dashboard at
# Project → Settings → Environment Variables. Never commit real values.

# ── Required for the AI Advisor feature (/api/advisor.js) ──
# Get a key at https://console.anthropic.com/settings/keys
# Anthropic's API has its own billing (separate from hosting) — see
# https://www.anthropic.com/pricing. Leaving this unset simply disables the
# AI Advisor button; the rest of the simulator keeps working.
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional, for scenario-saving & habit-tracking persistence ──
# (/api/scenarios.js and /api/habits.js). Create a free project at
# https://supabase.com, then run supabase/schema.sql in its SQL editor.
# Find these values at Project Settings → API in your Supabase dashboard.
# SUPABASE_SERVICE_ROLE_KEY is a SECRET — server-side only, never expose it
# to the browser.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
